diff --git a/cppsrc/openharmony/windowopenharmony.cpp b/cppsrc/openharmony/windowopenharmony.cpp
new file mode 100644
index 0000000..e97064f
--- /dev/null
+++ b/cppsrc/openharmony/windowopenharmony.cpp
@@ -0,0 +1,58 @@
+#include "windowopenharmony.h"
+
+#include <cstdio>
+#include <cstring>
+#include <string>
+
+namespace {
+
+bool readProcCmdlineArgv0(std::string* out) {
+  if (!out) {
+    return false;
+  }
+  char buf[1024];
+  std::memset(buf, 0, sizeof(buf));
+  FILE* f = std::fopen("/proc/self/cmdline", "rb");
+  if (!f) {
+    return false;
+  }
+  const size_t n = std::fread(buf, 1, sizeof(buf) - 1, f);
+  std::fclose(f);
+  if (n == 0) {
+    return false;
+  }
+  *out = std::string(buf);
+  return true;
+}
+
+}  // namespace
+
+Napi::Object windowopenharmony::getActiveWindowWrapped(const Napi::CallbackInfo& info) {
+  Napi::Env env = info.Env();
+  Napi::Object obj = Napi::Object::New(env);
+
+  obj.Set("os", "openharmony");
+  obj.Set("windowDesktop", "0");
+  obj.Set("windowType", "0");
+  obj.Set("windowPid", "0");
+  obj.Set("idleTime", "0");
+
+  std::string argv0;
+  if (readProcCmdlineArgv0(&argv0)) {
+    obj.Set("windowName", argv0);
+    obj.Set("windowClass", argv0);
+  } else {
+    obj.Set("windowName", "");
+    obj.Set("windowClass", "");
+  }
+
+  return obj;
+}
+
+Napi::Object windowopenharmony::Init(Napi::Env env, Napi::Object exports) {
+  exports.Set(
+    "getActiveWindow",
+    Napi::Function::New(env, windowopenharmony::getActiveWindowWrapped)
+  );
+  return exports;
+}
