diff --git a/scripts/gyp-is-openharmony-port.js b/scripts/gyp-is-openharmony-port.js
new file mode 100644
index 0000000..018ce81
--- /dev/null
+++ b/scripts/gyp-is-openharmony-port.js
@@ -0,0 +1,79 @@
+'use strict';
+/**
+ * Used from binding.gyp: eaw_oh_port% → "1" when this build targets OpenHarmony
+ * (on-device or OH SDK cross-compile), so we do not compile the Linux/X11 sources.
+ *
+ * Desktop Linux + X11: prints "0" so windowlinux.cpp + -lX11/-lXss/-lxcb stay enabled.
+ */
+const fs = require('fs');
+
+function print(v) {
+  process.stdout.write(v);
+}
+
+if (process.env.ELECTRON_ACTIVE_WINDOW_OH_PORT === '1') {
+  print('1');
+  process.exit(0);
+}
+
+if (process.platform === 'openharmony') {
+  print('1');
+  process.exit(0);
+}
+
+const execPath = String(process.execPath).toLowerCase();
+if (execPath.includes('openharmony')) {
+  print('1');
+  process.exit(0);
+}
+
+const tool = [
+  process.env.CC,
+  process.env.CXX,
+  process.env.npm_config_cc,
+  process.env.npm_config_cxx,
+  process.env.TARGET_CC,
+  process.env.TARGET_CXX,
+]
+  .filter(Boolean)
+  .join(' ')
+  .toLowerCase();
+
+if (
+  tool.includes('linux-ohos') ||
+  tool.includes('unknown-linux-ohos') ||
+  tool.includes('-ohos-clang') ||
+  tool.includes('aarch64-linux-ohos')
+) {
+  print('1');
+  process.exit(0);
+}
+
+for (const f of ['/etc/os-release', '/usr/etc/os-release']) {
+  try {
+    const s = fs.readFileSync(f, 'utf8');
+    const lower = s.toLowerCase();
+    if (/^id=openharmony\b/m.test(lower) || /^id=ohos\b/m.test(lower)) {
+      print('1');
+      process.exit(0);
+    }
+    if (/^name=.*openharmony/m.test(lower) || /^name=.*open harmony/m.test(lower)) {
+      print('1');
+      process.exit(0);
+    }
+  } catch (_) {
+    /* ignore */
+  }
+}
+
+try {
+  const ver = fs.readFileSync('/proc/version', 'utf8').toLowerCase();
+  if (ver.includes('openharmony') || ver.includes('ohos')) {
+    print('1');
+    process.exit(0);
+  }
+} catch (_) {
+  /* ignore */
+}
+
+print('0');
