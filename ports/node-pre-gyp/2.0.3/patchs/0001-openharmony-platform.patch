diff --git a/lib/util/versioning.js b/lib/util/versioning.js
index b69b367..bec9f47 100644
--- a/lib/util/versioning.js
+++ b/lib/util/versioning.js
@@ -271,6 +271,57 @@ function get_process_runtime(versions) {
 
 module.exports.get_process_runtime = get_process_runtime;
 
+const fs = require('fs');
+
+function read_os_release_contents() {
+  const paths = ['/etc/os-release', '/usr/etc/os-release'];
+  for (const p of paths) {
+    try {
+      return fs.readFileSync(p, 'utf8');
+    } catch (_) {
+      // continue
+    }
+  }
+  return '';
+}
+
+function host_seems_openharmony() {
+  if (process.platform === 'openharmony') {
+    return true;
+  }
+  if (process.platform !== 'linux') {
+    return false;
+  }
+  const rel = read_os_release_contents().toLowerCase();
+  return /^id=openharmony\b/m.test(rel) || /^id=ohos\b/m.test(rel);
+}
+module.exports.host_seems_openharmony = host_seems_openharmony;
+
+/**
+ * Platform string used in tarball paths ({platform}) and --target_platform.
+ * On OpenHarmony devices Node may still report process.platform === 'linux';
+ * we map that to 'openharmony' when /etc/os-release identifies OH, so install
+ * can fetch e.g. *-openharmony-arm64.tar.gz. Override with --target_platform
+ * or NODE_PRE_GYP_PLATFORM.
+ */
+function resolve_host_platform(options) {
+  if (options.target_platform) {
+    return options.target_platform;
+  }
+  const forced = process.env.NODE_PRE_GYP_PLATFORM;
+  if (forced) {
+    return forced;
+  }
+  if (process.platform === 'openharmony') {
+    return 'openharmony';
+  }
+  if (host_seems_openharmony()) {
+    return 'openharmony';
+  }
+  return process.platform;
+}
+module.exports.resolve_host_platform = resolve_host_platform;
+
 const default_package_name = '{module_name}-v{version}-{node_abi}-{platform}-{arch}.tar.gz';
 const default_remote_path = '';
 
